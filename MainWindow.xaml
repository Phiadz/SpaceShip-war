<Window x:Class="SpaceShipWar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Battleship2D.Presentation.Converters"
        Title="SpaceShip War - P2P"
        Width="1180"
        Height="780"
        Closed="Window_Closed">
    <Window.Resources>
    <local:EquippedToOpacityConverter x:Key="EquippedToOpacityConverter" />
    <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Window.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <Grid x:Name="RootGrid" Margin="16" MinWidth="1260" MinHeight="760">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="P2P Sci-Fi Battleship - Network Control" />
            <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" Foreground="#000000" Text="{Binding TurnHint}" />
            <TextBlock Margin="0,3,0,0" FontWeight="Bold" Foreground="#000000" Text="{Binding GameResult}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="Host IP:" />
            <TextBox Grid.Column="1" Margin="8,0,8,0" Text="{Binding HostIp, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Host Port:" />
            <TextBox Grid.Column="3" Margin="8,0,8,0" Text="{Binding HostPort, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Grid.Column="4" Margin="8,0,0,0" Text="{Binding DiscoveryPort, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <WrapPanel Grid.Row="2" Margin="0,12,0,0" ItemHeight="32">
            <Button Width="120" Margin="0,0,8,0" Content="Start Host" Command="{Binding StartHostCommand}" />
            <Button Width="140" Margin="0,0,8,0" Content="Start Announce" Command="{Binding StartHostAnnouncementCommand}" />
            <Button Width="130" Margin="0,0,8,0" Content="Listen Discovery" Command="{Binding StartDiscoveryListenCommand}" />
            <Button Width="100" Margin="0,0,8,0" Content="Connect" Command="{Binding ConnectCommand}" />
            <Button Width="100" Margin="0,0,8,0" Content="READY" Command="{Binding ConfirmReadyCommand}" />
            <Button Width="120" Margin="0,0,8,0" Content="Fire Random" Command="{Binding FireRandomCommand}" />
            <Button Width="100" Content="Stop All" Command="{Binding StopAllCommand}" />
        </WrapPanel>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" Margin="0,0,14,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Discovery Hosts" />
                        <ListBox Margin="0,8,0,12" Height="160" ItemsSource="{Binding DiscoveredHosts}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock FontWeight="SemiBold" Text="Placement Controls" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding PlacementShips}"
                                  SelectedItem="{Binding SelectedPlacementShip, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" />
                        <WrapPanel Margin="0,8,0,12">
                            <Button Width="92" Content="Rotate" Command="{Binding RotatePlacementCommand}" />
                            <Button Width="92" Margin="8,0,0,0" Content="Reset" Command="{Binding ResetPlacementCommand}" />
                            <TextBlock Margin="10,6,0,0" Foreground="#E9EEF7" Text="{Binding PlacementOrientationText}" />
                        </WrapPanel>

                        <TextBlock FontWeight="SemiBold" Text="Fleet Assets" />
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding FleetAssets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.InspectShipCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding}" 
                                                Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Width="48" Height="48" Background="#101820" CornerRadius="4" BorderBrush="#273647" BorderThickness="1">
                                                    <Image Source="{Binding ImagePath}" Stretch="Uniform" />
                                                </Border>
                                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding Name}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock FontWeight="SemiBold" Text="Local Board (10x10)" />
                    
                    <Border Margin="0,8,0,0" CornerRadius="6" Padding="4" BorderBrush="#51657A" BorderThickness="2"
                            Width="432" Height="432" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Border.Background>
                            <ImageBrush ImageSource="pack://siteoforigin:,,,/Assets/space_breaker_asset/Background/stars_texture.png" Stretch="Uniform" Opacity="0.9" />
                        </Border.Background>
                        
                        <Grid Margin="2" Width="420" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center">
    
                            <ItemsControl ItemsSource="{Binding LocalBoardCells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="10" Rows="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="40" Height="40" Margin="1" Padding="0"
                                                AllowDrop="True" DragOver="BoardCell_DragOver" Drop="BoardCell_Drop"
                                                Command="{Binding CellCommand}" Background="{Binding CellBrush}"
                                                BorderBrush="#1D2430" BorderThickness="1">
                                            </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding VisualPlacedShips}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}" Height="{Binding Height}">
                                            <Grid.LayoutTransform>
                                                <RotateTransform Angle="{Binding Rotation}" />
                                            </Grid.LayoutTransform>

                                            <Image Source="{Binding ImagePath}" Stretch="Uniform" />

                                            <ItemsControl ItemsSource="{Binding EquippedWeapons}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Image Source="{Binding ImagePath}" Width="{Binding Width}" Height="{Binding Height}" Stretch="Uniform" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding LocalBoardCells}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="10" Rows="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="40" Height="40" Margin="1">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="{Binding Marker}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="Enemy Board (Click To Fire)" />
                    <Border Margin="0,8,0,0" BorderThickness="2" CornerRadius="4" 
                            Width="432" Height="432" HorizontalAlignment="Left" VerticalAlignment="Top">                  
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#51657A" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMyTurn}" Value="True">
                                        <Setter Property="BorderBrush" Value="#F7C744" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Border.Background>
                            <ImageBrush ImageSource="pack://siteoforigin:,,,/Assets/space_breaker_asset/Background/star2jpg.jpg" Stretch="UniformToFill" Opacity="0.9" />
                        </Border.Background>
                        
                        <ItemsControl Margin="2" Width="420" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center" ItemsSource="{Binding EnemyBoardCells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="10" Rows="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="40" Height="40" Margin="1">
                                        <Rectangle Fill="#3C6496" Opacity="0.4" />
                                        <Button Padding="0"
                                                AllowDrop="True"
                                                DragOver="BoardCell_DragOver"
                                                Drop="BoardCell_Drop"
                                                Command="{Binding CellCommand}"
                                                Background="{Binding CellBrush}"
                                                BorderBrush="#1D2430"
                                                BorderThickness="1">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="{Binding Marker}" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" /> <ColumnDefinition Width="1.5*" /> <ColumnDefinition Width="3*" /> </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,8,0" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="6" Background="#101820">
                    <Grid>
                        <TextBlock Text="Ship Inspector" HorizontalAlignment="Right" Foreground="#4CAF50" Margin="5" FontSize="10" Opacity="0.5"/>
                        
                        <ContentControl Content="{Binding SelectedInspectorShip}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Image Source="{Binding ImagePath}" Stretch="Uniform" Margin="20" />
                                        <StackPanel VerticalAlignment="Bottom" Margin="10">
                                            <TextBlock Text="PREVIEW" FontWeight="Bold" Foreground="#4CAF50" />
                                            <ItemsControl ItemsSource="{Binding EquippedWeapons}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="11" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                        
                        <TextBlock Text="Select a ship to inspect" Visibility="{Binding SelectedInspectorShip, Converter={StaticResource NullToVisibilityConverter}}" 
                                VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Margin="0,0,8,0" BorderBrush="#2196F3" BorderThickness="2" CornerRadius="6" Background="#101820">
                    <StackPanel>
                        <TextBlock Text="Inventory" Margin="8,4" FontWeight="Bold" Foreground="#2196F3" />
                        <ScrollViewer Height="180">
                            <ItemsControl ItemsSource="{Binding Inventory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4" Padding="4" Background="#1D2430" CornerRadius="3"
                                                Opacity="{Binding IsEquipped, Converter={StaticResource EquippedToOpacityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" Background="#1D2430" CornerRadius="2" Margin="0,0,8,0">
                                                    <Image Source="{Binding Item.ImagePath}" Stretch="Uniform" />
                                                </Border>
                                                <TextBlock Text="{Binding Item.Name}" Foreground="White" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" BorderBrush="#F44336" BorderThickness="2" CornerRadius="6" Background="#101820">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="80" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="8,4">
                            <TextBlock Text="Armory" FontWeight="Bold" Foreground="#F44336" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentBudget, StringFormat='Budget: {0} Credits'}" Margin="20,0,0,0" Foreground="#F7C744" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{Binding ShopItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4" Width="130" Padding="6" Background="#1D2430" CornerRadius="4" BorderBrush="#333" BorderThickness="1">
                                            
                                            <Border.ToolTip>
                                                <ToolTip Background="#101820" BorderBrush="#F44336" Foreground="White">
                                                    <Grid>
                                                        <StackPanel Margin="0,0,30,0">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="11" TextWrapping="Wrap" Height="30"/>
                                                            <TextBlock Text="{Binding Cost, StringFormat='{}{0} CR'}" Foreground="#F7C744" FontWeight="Bold" />
                                                            <TextBlock Text="{Binding Category}" FontSize="9" Foreground="Gray" />
                                                        </StackPanel>
                                                        
                                                        <Image Source="{Binding ImagePath}" 
                                                            Width="36" Height="36" 
                                                            HorizontalAlignment="Right" 
                                                            VerticalAlignment="Bottom" 
                                                            Stretch="Uniform" />
                                                    </Grid>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding DataContext.BuyItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectShopItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="11" TextWrapping="Wrap" Height="30"/>
                                                <TextBlock Text="{Binding Cost, StringFormat='{}{0} CR'}" Foreground="#F7C744" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Category}" FontSize="9" Foreground="Gray" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border Grid.Row="2" Margin="8,0,8,8" Padding="8" Background="#161B22" CornerRadius="4" BorderBrush="#273647" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedShopItem.Description}" Foreground="#A0B0C0" TextWrapping="Wrap" FontSize="12" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>
