<Window x:Class="SpaceShipWar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpaceShip War - P2P"
        Width="1180"
        Height="780"
        Closed="Window_Closed">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <Grid x:Name="RootGrid" Margin="16" MinWidth="1260" MinHeight="760">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="P2P Sci-Fi Battleship - Network Control" />
            <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" Foreground="#000000" Text="{Binding TurnHint}" />
            <TextBlock Margin="0,3,0,0" FontWeight="Bold" Foreground="#000000" Text="{Binding GameResult}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="Host IP:" />
            <TextBox Grid.Column="1" Margin="8,0,8,0" Text="{Binding HostIp, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Host Port:" />
            <TextBox Grid.Column="3" Margin="8,0,8,0" Text="{Binding HostPort, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Grid.Column="4" Margin="8,0,0,0" Text="{Binding DiscoveryPort, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <WrapPanel Grid.Row="2" Margin="0,12,0,0" ItemHeight="32">
            <Button Width="120" Margin="0,0,8,0" Content="Start Host" Command="{Binding StartHostCommand}" />
            <Button Width="140" Margin="0,0,8,0" Content="Start Announce" Command="{Binding StartHostAnnouncementCommand}" />
            <Button Width="130" Margin="0,0,8,0" Content="Listen Discovery" Command="{Binding StartDiscoveryListenCommand}" />
            <Button Width="100" Margin="0,0,8,0" Content="Connect" Command="{Binding ConnectCommand}" />
            <Button Width="100" Margin="0,0,8,0" Content="READY" Command="{Binding ConfirmReadyCommand}" />
            <Button Width="120" Margin="0,0,8,0" Content="Fire Random" Command="{Binding FireRandomCommand}" />
            <Button Width="100" Content="Stop All" Command="{Binding StopAllCommand}" />
        </WrapPanel>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" Margin="0,0,14,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Discovery Hosts" />
                        <ListBox Margin="0,8,0,12" Height="160" ItemsSource="{Binding DiscoveredHosts}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock FontWeight="SemiBold" Text="Placement Controls" />
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding PlacementShips}"
                                  SelectedItem="{Binding SelectedPlacementShip, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" />
                        <WrapPanel Margin="0,8,0,12">
                            <Button Width="92" Content="Rotate" Command="{Binding RotatePlacementCommand}" />
                            <Button Width="92" Margin="8,0,0,0" Content="Reset" Command="{Binding ResetPlacementCommand}" />
                            <TextBlock Margin="10,6,0,0" Foreground="#E9EEF7" Text="{Binding PlacementOrientationText}" />
                        </WrapPanel>

                        <TextBlock FontWeight="SemiBold" Text="Fleet Assets" />
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding FleetAssets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="48" Height="48" Background="#101820" CornerRadius="4" BorderBrush="#273647" BorderThickness="1">
                                            <Image Source="{Binding ImagePath}" Stretch="Uniform" />
                                        </Border>
                                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock FontWeight="SemiBold" Text="Local Board (10x10)" />
                    
                    <Border Margin="0,8,0,0" CornerRadius="6" Padding="4" BorderBrush="#51657A" BorderThickness="2"
                            Width="432" Height="432" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Border.Background>
                            <ImageBrush ImageSource="pack://siteoforigin:,,,/Assets/space_breaker_asset/Background/stars_texture.png" Stretch="Uniform" Opacity="0.9" />
                        </Border.Background>
                        
                        <Grid Margin="2" Width="420" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center">
    
                            <ItemsControl ItemsSource="{Binding LocalBoardCells}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="10" Rows="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="40" Height="40" Margin="1" Padding="0"
                                                AllowDrop="True" DragOver="BoardCell_DragOver" Drop="BoardCell_Drop"
                                                Command="{Binding CellCommand}" Background="{Binding CellBrush}"
                                                BorderBrush="#1D2430" BorderThickness="1">
                                            </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding VisualPlacedShips}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding ImagePath}" Width="{Binding Width}" Height="{Binding Height}" Stretch="Fill">
                                            <Image.LayoutTransform>
                                                <RotateTransform Angle="{Binding Rotation}" />
                                            </Image.LayoutTransform>
                                        </Image>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding LocalBoardCells}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="10" Rows="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="40" Height="40" Margin="1">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="{Binding Marker}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="Enemy Board (Click To Fire)" />
                    <Border Margin="0,8,0,0" BorderThickness="2" CornerRadius="4" 
                            Width="432" Height="432" HorizontalAlignment="Left" VerticalAlignment="Top">                  
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#51657A" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMyTurn}" Value="True">
                                        <Setter Property="BorderBrush" Value="#F7C744" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Border.Background>
                            <ImageBrush ImageSource="pack://siteoforigin:,,,/Assets/space_breaker_asset/Background/star2jpg.jpg" Stretch="UniformToFill" Opacity="0.9" />
                        </Border.Background>
                        
                        <ItemsControl Margin="2" Width="420" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center" ItemsSource="{Binding EnemyBoardCells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="10" Rows="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="40" Height="40" Margin="1">
                                        <Rectangle Fill="#3C6496" Opacity="0.4" />
                                        <Button Padding="0"
                                                AllowDrop="True"
                                                DragOver="BoardCell_DragOver"
                                                Drop="BoardCell_Drop"
                                                Command="{Binding CellCommand}"
                                                Background="{Binding CellBrush}"
                                                BorderBrush="#1D2430"
                                                BorderThickness="1">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="{Binding Marker}" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Margin="0,14,0,0" Padding="12" Background="Transparent" BorderBrush="#4A6A8A" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#000000" Text="Status" />
                        <TextBlock Margin="0,4,0,0" Foreground="#000000" Text="{Binding ConnectionStatus}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock FontWeight="SemiBold" Foreground="#000000" Text="Session" />
                        <TextBlock Margin="0,4,0,0" Foreground="#000000" Text="{Binding SessionStatus}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock FontWeight="SemiBold" Foreground="#000000" Text="Turn" />
                        <TextBlock Margin="0,4,0,0" Foreground="#000000" Text="{Binding IsMyTurn}" />
                        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#000000" Text="{Binding LastEvent}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>
